const fs = require('fs');
const path = require('path');
const { spawn } = require('child_process');

// Configuration
const CONFIG = {
  checkpointDir: process.env.CHECKPOINT_DIR || path.join(process.env.HOME, '.task-checkpoints'),
  learningDir: process.env.LEARNING_DIR || path.join(process.env.HOME, '.openclaw', 'workspace', '.learnings'),
  maxRetries: parseInt(process.env.MAX_RETRIES) || 3,
  maxParallelTasks: parseInt(process.env.MAX_PARALLEL) || 3,
};

// Ensure directories exist
if (!fs.existsSync(CONFIG.checkpointDir)) {
  fs.mkdirSync(CONFIG.checkpointDir, { recursive: true });
}

if (!fs.existsSync(CONFIG.learningDir)) {
  fs.mkdirSync(CONFIG.learningDir, { recursive: true });
}

