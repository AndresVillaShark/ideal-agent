/**
 * Resume from checkpoint
 */
async function resumeTask(taskId) {
  const checkpointDir = path.join(CONFIG.checkpointDir, taskId);
  
  if (!fs.existsSync(checkpointDir)) {
    throw new Error(`No checkpoints found for task: ${taskId}`);
  }
  
  console.log(`🔄 Resuming task: ${taskId}\n`);
  
  // Load checkpoints
  const checkpoints = fs.readdirSync(checkpointDir)
    .filter(f => f.startsWith('checkpoint-'))
    .map(f => JSON.parse(fs.readFileSync(path.join(checkpointDir, f), 'utf8')));
  
  console.log(`📊 Found ${checkpoints.length} checkpoints\n`);
  console.log(JSON.stringify(checkpoints, null, 2));
  
  return { taskId, checkpoints };
}

/**
 * Display status of running task
 */
async function taskStatus(taskId) {
  const checkpointDir = path.join(CONFIG.checkpointDir, taskId);
  
  if (!fs.existsSync(checkpointDir)) {
    console.log(`ℹ️  No checkpoints found for task: ${taskId}`);
    return null;
  }
  
  const checkpoints = fs.readdirSync(checkpointDir)
    .filter(f => f.startsWith('checkpoint-'))
    .map(f => {
      const data = JSON.parse(fs.readFileSync(path.join(checkpointDir, f), 'utf8'));
      return {
        file: f,
        step: data.stepId,
        status: data.status,
        timestamp: data.timestamp,
      };
    });
  
  console.log(`📊 Status for task: ${taskId}\n`);
  console.log(`💾 Checkpoints: ${checkpoints.length}\n`);
  checkpoints.forEach(cp => {
    console.log(`  ${cp.file}: ${cp.status} (${cp.timestamp})`);
  });
  
  return checkpoints;
}

/**
 * List recent learnings
 */
async function listLearnings(count = 5) {
  const learningDir = CONFIG.learningDir;
  
  if (!fs.existsSync(learningDir)) {
    console.log('No learnings found.\n');
    return [];
  }
  
  const filings = fs.readdirSync(learningDir)
    .filter(f => f.endsWith('.json'))
    .sort()
    .reverse()
    .slice(0, count);
  
  console.log(`📚 Recent Learnings (${filelings.length}):\n`);
  filings.forEach(file => {
    const data = JSON.parse(fs.readFileSync(path.join(learningDir, file), 'utf8'));
    console.log(`  ${file}:`);
    console.log(`    ${data.task || 'No description'}`);
    console.log(`    Duration: ${data.duration || 'N/A'}`);
    console.log(`    Success Rate: ${data.success_rate ? `${(data.success_rate * 100).toFixed(0)}%` : 'N/A'}`);
    console.log('');
  });
  
  return filings;
}

/**
 * Utility: sleep
 */
function sleep(ms) {
  return new Promise(resolve => setTimeout(resolve, ms));
}

// CLI interface
async function main() {
  const args = process.argv.slice(2);
  const command = args[0];
  
  if (!command) {
    console.log('Task Orchestrator CLI v1.0.0');
    console.log('');
    console.log('Usage:');
    console.log('  task-orch start "<task description>" [options]');
    console.log('  task-orch resume <task-id>');
    console.log('  task-orch status <task-id>');
    console.log('  task-orch learnings [--recent=N]');
    console.log('  task-orch analyze "<task description>" --dry-run');
    console.log('  task-orch init');
    console.log('  task-orch --help');
    process.exit(0);
  }
  
  try {
    switch (command) {
      case 'start': {
        const description = args[1];
        if (!description) {
          console.error('❌ Error: Task description required');
          process.exit(1);
        }
        
        const options = parseOptions(args.slice(2));
        await runOrchestration(description, options);
        break;
      }
      
      case 'resume': {
        const taskId = args[1];
        if (!taskId) {
          console.error('❌ Error: Task ID required');
          process.exit(1);
        }
        await resumeTask(taskId);
        break;
      }
      
      case 'status': {
        const taskId = args[1];
        if (!taskId) {
          console.error('❌ Error: Task ID required');
          process.exit(1);
        }
        await taskStatus(taskId);
        break;
      }
      
      case 'learnings': {
        const count = parseInt(args[1]?.replace('--recent=', '')) || 5;
        await listLearnings(count);
        break;
      }
      
      case 'analyze': {
        const description = args[1];
        if (!description) {
          console.error('❌ Error: Task description required');
          process.exit(1);
        }
        
        const options = parseOptions(args.slice(2));
        await runOrchestration(description, { ...options, dryRun: true });
        break;
      }
      
      case 'init': {
        // Initialize directories and config
        const configPath = path.join(CONFIG.checkpointDir, 'config.json');
        if (!fs.existsSync(configPath)) {
          fs.writeFileSync(configPath, JSON.stringify(CONFIG, null, 2));
        }
        
        console.log('✅ Task Orchestrator initialized');
        console.log(`   Checkpoint dir: ${CONFIG.checkpointDir}`);
        console.log(`   Learning dir: ${CONFIG.learningDir}`);
        break;
      }
      
      default:
        console.error(`❌ Unknown command: ${command}`);
        process.exit(1);
    }
  } catch (error) {
    console.error(`❌ Error: ${error.message}`);
    process.exit(1);
  }
}

function parseOptions(args) {
  const options = {};
  args.forEach(arg => {
    if (arg.startsWith('--')) {
      const [key, value] = arg.slice(2).split('=');
      options[key] = value || true;
    }
  });
  return options;
}

// Run CLI
main();
