/**
 * Save execution checkpoint for recovery
 */
async function saveCheckpoint(taskId, stepId, data) {
  const checkpointPath = path.join(CONFIG.checkpointDir, taskId);
  
  if (!fs.existsSync(checkpointPath)) {
    fs.mkdirSync(checkpointPath, { recursive: true });
  }
  
  const checkpointFile = path.join(checkpointPath, `checkpoint-${stepId}.json`);
  fs.writeFileSync(checkpointFile, JSON.stringify(data, null, 2));
  
  console.log(`  📝 Checkpoint saved: ${checkpointFile}`);
}

