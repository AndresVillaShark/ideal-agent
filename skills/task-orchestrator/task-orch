/**
 * Analyze a task and decompose it into subtasks using LLM
 */
async function analyzeTask(taskDescription) {
  console.log(`🔍 Analyzing task:\n${taskDescription}\n`);
  
  const taskId = `task-${Date.now()}`;
  
  // Call LLM to decompose the task
  const analysis = await llmDecomposeTask(taskId, taskDescription);
  
  console.log('✅ Task decomposition complete\n');
  console.log(`   Complexity: ${analysis.complexity}`);
  console.log(`   Estimated subtasks: ${analysis.subtasks.length}`);
  console.log(`   Parallel groups: ${analysis.parallelGroups.length}\n`);
  
  return analysis;
}

/**
 * Decompose task using LLM API call
 */
async function llmDecomposeTask(taskId, taskDescription) {
  // Build prompt for LLM
  const prompt = `You are an expert work decomposition engine. Analyze the following task and break it into executable subtasks.

TASK: "${taskDescription}"

Return a JSON object with this exact structure:
{
  "taskId": "<id>",
  "description": "<task description>",
  "timestamp": "<ISO timestamp>",
  "complexity": "low|medium|high",
  "estimatedSteps": <integer>,
  "subtasks": [
    {
      "id": "step-1",
      "name": "<short name>",
      "description": "<what to do>",
      "tool": "<recommended tool>",
      "input": "<input data if any>",
      "estimatedDuration": "<duration estimate>"
    }
  ],
  "dependencies": {
    "step-2": ["step-1"]
  },
  "parallelGroups": [
    ["step-1", "step-2"]
  ],
  "recommendedTools": ["tool1", "tool2"]
}

Analyze carefully and provide a complete, executable breakdown. Use available tools like: agent-browser, web_search, gog (Google Workspace), github, file operations, text_generation, summarize, clawhub, exec, etc.`;

  try {
    // Call LLM service (using available text generation)
    const llmResponse = await callLLM(prompt);
    
    // Parse the JSON response
    const jsonMatch = llmResponse.match(/\{[\s\S]*\}/);
    if (jsonMatch) {
      const parsed = JSON.parse(jsonMatch[0]);
      parsed.taskId = taskId; // Override with our ID
      return parsed;
    }
    
    // Fallback to rule-based if parsing fails
    return await ruleBasedDecompose(taskId, taskDescription);
  } catch (error) {
    console.error(`⚠️  LLM decomposition failed: ${error.message}`);
    console.log('   Falling back to rule-based decomposition\n');
    return await ruleBasedDecompose(taskId, taskDescription);
  }
}

