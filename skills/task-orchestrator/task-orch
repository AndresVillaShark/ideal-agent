/**
 * Rule-based task decomposition (fallback)
 */
async function ruleBasedDecompose(taskId, taskDescription) {
  const description = taskDescription.toLowerCase();
  const subtasks = [];
  const parallelGroups = [];
  const dependencies = {};
  
  // Pattern matching for common task types
  if (description.includes('job application') || description.includes('apply to')) {
    subtasks.push(
      { id: 'step-1', name: 'Find positions', description: 'Search for open roles', tool: 'web_search', input: 'job title, company, location', estimatedDuration: '5min' },
      { id: 'step-2', name: 'Extract requirements', description: 'Parse job descriptions', tool: 'summarize-pro', input: 'job postings', estimatedDuration: '3min' },
      { id: 'step-3', name: 'Match skills', description: 'Compare to your skills', tool: 'knowledge', input: 'resume, skills', estimatedDuration: '2min' },
      { id: 'step-4', name: 'Tailor resume', description: 'Customize for each role', tool: 'file_edit', input: 'resume template', estimatedDuration: '5min' },
      { id: 'step-5', name: 'Write cover letters', description: 'Generate personalized letters', tool: 'text_generation', input: 'job requirements', estimatedDuration: '5min' },
      { id: 'step-6', name: 'Fill applications', description: 'Submit via web forms', tool: 'agent-browser', input: 'application URLs', estimatedDuration: '10min' },
      { id: 'step-7', name: 'Track submissions', description: 'Log all applications', tool: 'file_write', input: 'application data', estimatedDuration: '2min' }
    );
    
    // Dependencies
    dependencies['step-2'] = ['step-1'];
    dependencies['step-3'] = ['step-2'];
    dependencies['step-4'] = ['step-3'];
    dependencies['step-5'] = ['step-3'];
    dependencies['step-6'] = ['step-4', 'step-5'];
    dependencies['step-7'] = ['step-6'];
    
    // Parallel groups (tailoring resume and writing letters can happen in parallel)
    parallelGroups.push(['step-4', 'step-5']);
    
  } else if (description.includes('blog') || description.includes('content') || description.includes('post')) {
    subtasks.push(
      { id: 'step-1', name: 'Research topics', description: 'Find relevant information', tool: 'web_search', input: 'topic keywords', estimatedDuration: '5min' },
      { id: 'step-2', name: 'Create outline', description: 'Structure the post', tool: 'text_generation', input: 'research results', estimatedDuration: '3min' },
      { id: 'step-3', name: 'Write content', description: 'Generate main content', tool: 'text_generation', input: 'outline', estimatedDuration: '15min' },
      { id: 'step-4', name: 'Create code examples', description: 'Generate working code', tool: 'agent-browser', input: 'topic requirements', estimatedDuration: '10min' },
      { id: 'step-5', name: 'Test examples', description: 'Verify code works', tool: 'exec', input: 'code snippets', estimatedDuration: '5min' },
      { id: 'step-6', name: 'Format as Markdown', description: 'Prepare final post', tool: 'file_edit', input: 'content + code', estimatedDuration: '5min' },
      { id: 'step-7', name: 'Publish', description: 'Upload to blog platform', tool: 'github', input: 'final content', estimatedDuration: '2min' }
    );
    
    dependencies['step-2'] = ['step-1'];
    dependencies['step-3'] = ['step-2'];
    dependencies['step-4'] = ['step-3'];
    dependencies['step-5'] = ['step-4'];
    dependencies['step-6'] = ['step-3', 'step-5'];
    dependencies['step-7'] = ['step-6'];
    
  } else {
    // Generic decomposition for unknown tasks
    const steps = ['Research', 'Planning', 'Execution', 'Review', 'Documentation'];
    steps.forEach((step, idx) => {
      subtasks.push({
        id: `step-${idx+1}`,
        name: step,
        description: `Complete ${step.toLowerCase()} phase`,
        tool: 'text_generation',
        input: 'task context',
        estimatedDuration: '10min'
      });
      
      if (idx > 0) {
        dependencies[`step-${idx+1}`] = [`step-${idx}`];
      }
    });
  }
  
  return {
    taskId,
    description: taskDescription,
    timestamp: new Date().toISOString(),
    complexity: 'medium',
    estimatedSteps: subtasks.length,
    subtasks,
    dependencies,
    parallelGroups,
    recommendedTools: [...new Set(subtasks.map(s => s.tool))]
  };
}

/**
 * Execute a single subtask with retry logic
 */
async function executeSubtask(subtask, taskId) {
  console.log(`⚙️  Executing subtask: ${subtask.name}`);
  console.log(`   Tool: ${subtask.tool}`);
  console.log(`   Input: ${subtask.input}\n`);
  
  for (let attempt = 1; attempt <= CONFIG.maxRetries; attempt++) {
    console.log(`  Attempt ${attempt}/${CONFIG.maxRetries}`);
    
    try {
      // Execute the subtask using appropriate tool
      const result = await dispatchToTool(subtask);
      
      // Save checkpoint
      await saveCheckpoint(taskId, subtask.id, {
        status: 'completed',
        attempt: attempt,
        result: result,
        timestamp: new Date().toISOString(),
        subtask: subtask.name
      });
      
      console.log(`  ✅ Completed successfully\n`);
      return { success: true, result, attempt };
    } catch (error) {
      console.error(`  ❌ Attempt ${attempt} failed: ${error.message}\n`);
      
      if (attempt === CONFIG.maxRetries) {
        await saveCheckpoint(taskId, subtask.id, {
          status: 'failed',
          attempts: attempt,
          error: error.message,
          timestamp: new Date().toISOString(),
          subtask: subtask.name
        });
        
        return { success: false, error: error.message, attempts: attempt };
      }
      
      // Wait before retry (exponential backoff)
      const waitTime = Math.pow(2, attempt) * 1000;
      console.log(`  ⏳ Waiting ${waitTime}ms before retry...\n`);
      await sleep(waitTime);
    }
  }
}

